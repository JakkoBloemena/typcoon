# Typcoon — backend env-vars (zet deze in Vercel → Project → Settings → Environment Variables).
# De frontend werkt volledig zonder deze waarden; ze zijn nodig voor account/sync/mails.

# Supabase (Project Settings → API). De service-role sleutel is SERVER-ONLY — nooit in de client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (e-mail). Zonder RESEND_API_KEY worden er stil geen mails verstuurd (niets breekt).
RESEND_API_KEY=
EMAIL_FROM=Typcoon <hallo@typcoon.com>

# Cron + prefs-links. Eén geheim dat de cron beveiligt én de "meldingen aanpassen"-links tekent.
# Vercel stuurt dit automatisch mee als Bearer-token naar de cron-route.
CRON_SECRET=

# Publieke site-URL (voor links in e-mails).
SITE_URL=https://typcoon.com

# Telegram ops-meldingen (optioneel): een pingetje bij een nieuw account. Zonder deze
# twee gebeurt er stil niets. Bot maken via @BotFather; chat-id via @userinfobot of de
# getUpdates-API. TELEGRAM_CHAT_ID mag een persoonlijke chat of een (groeps)kanaal zijn.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optionele kostenplafonds (globaal, per uur). Standaard 100 / 60 / 2000.
MAX_CREATE_HOUR=100
MAX_EMAIL_HOUR=60
MAX_TRACK_HOUR=2000

# Schoollicentie-codes (assignment 018/TBD-A): ondertekent + verifieert licentiecodes
# (api/_licence.js). SERVER-ONLY, nooit in de client. Zonder deze var geeft
# /api/school/redeem netjes 'not_configured' terug (het spel blijft lokaal doorspelen).
SCHOOL_LICENSE_SECRET=
